# Copy this to .env.local and adjust for your setup

# Backend Socket.IO URL
VITE_SOCKET_URL=http://localhost:8000

# Pipeline network ID (must match the ID used in transient_simulation_service.py)
VITE_PIPELINE_ID=alaska

# Socket.IO event name emitted by broadcast_live_pipeline_update()
# Check app/sockets/handlers.py for the exact event name
VITE_LIVE_EVENT=live_pipeline_update
